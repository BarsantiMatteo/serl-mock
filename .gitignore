# -----------------------------------------------------------
# PYTHON ARTIFACTS
# -----------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
*.py[oc]

# Build artifacts
build/
dist/
wheels/
*.egg-info/
*.egg

# Byte-compiled / optimized / DLL files
*.so
*.dll
*.dylib

# -----------------------------------------------------------
# ENVIRONMENTS
# -----------------------------------------------------------
# uv creates .venv automatically
.venv/
.env/
env/
venv/

# -----------------------------------------------------------
# DATA 
# -----------------------------------------------------------
# Generated outputs — recreated by scripts/generate_mock_data.py
data/mock/*.csv
!data/mock/bst_dates_to_2030.csv
data/mock/serl_smart_meter_hh_edition08/
data/mock/serl_smart_meter_daily_edition08/
data/mock/serl_climate_data_edition08/

# Prevent accidental commit of large real datasets (Edition08 folder)
data/Edition08/

# -----------------------------------------------------------
# DOCUMENTATION FILES 
# -----------------------------------------------------------
# Only ignore large PDFs; CSV data dictionaries are tracked inputs
docs/documentation/*.pdf
working_notes.md

# -----------------------------------------------------------
# DUCKDB FILES 
# -----------------------------------------------------------
*.duckdb

# -----------------------------------------------------------
# JUPYTER NOTEBOOKS
# -----------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_convert/
**/.ipynb_checkpoints/

# -----------------------------------------------------------
# EDITOR / SYSTEM FILES
# -----------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------
# LOGS / TEMP / CACHE
# -----------------------------------------------------------
*.log
*.tmp
*.temp
*.cache
.cache/
__snapshots__/
coverage/
htmlcov/

# -----------------------------------------------------------
# PROJECT-SPECIFIC IGNORE RULES
# -----------------------------------------------------------

# Automatically generated mock smart meter files
data/mock/serl_smart_meter_hh_edition08/*

# Allow placeholder
!data/mock/serl_smart_meter_hh_edition08/.gitkeep


# Ignore VS Code settings folder (contains user-specific settings and should not be committed)
.vscode/