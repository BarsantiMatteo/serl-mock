# -----------------------------------------------------------
# PYTHON ARTIFACTS
# -----------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl
*.py[oc]

# Build artifacts
build/
dist/
wheels/
*.egg-info/
*.egg

# Byte-compiled / optimized / DLL files
*.so
*.dll
*.dylib

# -----------------------------------------------------------
# ENVIRONMENTS
# -----------------------------------------------------------
# uv creates .venv automatically
.venv/
.env/
env/
venv/

# -----------------------------------------------------------
# DATA 
# -----------------------------------------------------------
data/
data/mock/*
!data/mock/.gitkeep

# Prevent accidental commit of large real datasets (Edition08 folder)
data/Edition08/

# -----------------------------------------------------------
# DOCUMENTATION FILES 
# -----------------------------------------------------------
documentation/
documentation/*.pdf

# -----------------------------------------------------------
# DUCKDB FILES 
# -----------------------------------------------------------
*.duckdb

# -----------------------------------------------------------
# JUPYTER NOTEBOOKS
# -----------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_convert/
**/.ipynb_checkpoints/

# -----------------------------------------------------------
# EDITOR / SYSTEM FILES
# -----------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm
.idea/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
desktop.ini

# -----------------------------------------------------------
# LOGS / TEMP / CACHE
# -----------------------------------------------------------
*.log
*.tmp
*.temp
*.cache
.cache/
__snapshots__/
coverage/
htmlcov/

# -----------------------------------------------------------
# PROJECT-SPECIFIC IGNORE RULES
# -----------------------------------------------------------

# Automatically generated mock smart meter files
data/mock/serl_smart_meter_hh_edition08/*

# Allow placeholder
!data/mock/serl_smart_meter_hh_edition08/.gitkeep
